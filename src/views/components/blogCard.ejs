<div class="blog-item">
  <div class="blog-img">
    <div class="blog-img-inner">
      <img
        class="img-fluid w-100 rounded-top"
        src="assets/<%= imageSrc %>"
        alt="Image"
      />
      <div class="blog-icon">
        <a href="#" class="my-auto"
          ><i class="fas fa-link fa-2x text-white"></i
        ></a>
      </div>
    </div>
    <div
      class="blog-info d-flex align-items-center border border-start-0 border-end-0"
    >
      <small class="flex-fill text-center border-end py-2"
        ><i class="fa fa-calendar-alt text-primary me-2"></i><%= date %></small
      >
      <a
        href="#"
        class="btn-hover flex-fill text-center text-white border-end py-2"
        ><i class="fa fa-thumbs-up text-primary me-2"></i><%= likesCount %>k</a
      >
      <a href="#" class="btn-hover flex-fill text-center text-white py-2"
        ><i class="fa fa-comments text-primary me-2"></i><%= commentsCount
        %>k</a
      >
    </div>
  </div>
  <div class="blog-content border border-top-0 rounded-bottom p-4">
    <p class="mb-3">Posted By: <%= postedBy %></p>
    <a href="#" class="h4"><%= title %></a>
    <p class="my-3"><%= description %></p>
    <a href="#" class="btn btn-primary rounded-pill py-2 px-4">Read More</a>
  </div>
</div>
