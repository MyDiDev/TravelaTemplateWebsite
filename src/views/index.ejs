          <li data-bs-target="#carouselId" data-bs-slide-to="2"></li>
        </ol>
        <div class="carousel-inner" role="listbox">
            <% carouselItems.forEach((item, i) => { %>
                <%- include("components/carouselItem", {title: item.title, description: item.description, phrase: item.phrase, imageSrc: item.imageSrc, active: item.active}) %>
            <% }); %>
